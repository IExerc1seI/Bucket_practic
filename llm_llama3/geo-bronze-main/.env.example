# ---------- LLM ----------
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ---------- MinIO ----------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=geo-bronze
MINIO_SECURE=false

# ---------- Streaming large files ----------
STREAMING_THRESHOLD_BYTES=52428800   # 50 MB — threshold for switching to streaming
STREAMING_CHUNK_SIZE_BYTES=5242880   # 5 MB — multipart chunk size

# ---------- API keys for sources ----------
VISICOM_API_KEY=                 # Visicom basemap key (optional, source enabled=false without it)

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_FORMAT=json
